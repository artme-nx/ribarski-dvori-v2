{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "stone": {
        "100": { "$value": "#EDE7DA", "$type": "color" },
        "200": { "$value": "#D8CFBC", "$type": "color" },
        "400": { "$value": "#A99C87", "$type": "color" },
        "600": { "$value": "#6B5F4F", "$type": "color" },
        "800": { "$value": "#392F26", "$type": "color" },
        "900": { "$value": "#241D17", "$type": "color" },
        "950": { "$value": "#16110D", "$type": "color" }
      },
      "sea": {
        "300": { "$value": "#8FC2BA", "$type": "color" },
        "500": { "$value": "#2F7A78", "$type": "color" },
        "700": { "$value": "#1B4F4E", "$type": "color" }
      },
      "ember": {
        "400": { "$value": "#D97D4A", "$type": "color" },
        "600": { "$value": "#B8501F", "$type": "color" },
        "800": { "$value": "#5E2410", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-fraunces), 'Fraunces', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-manrope), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-geist-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "settle": { "$value": "1.0s", "$type": "duration" },
        "drift": { "$value": "2.2s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "tide": { "$value": "cubic-bezier(0.45, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.18em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.stone.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "popover": { "$value": "{primitive.color.stone.900}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "primary": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.stone.950}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.stone.400}", "$type": "color" },
    "accent": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.stone.100}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.ember.600}", "$type": "color" },
    "border": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "input": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "ring": { "$value": "{primitive.color.sea.500}", "$type": "color" },
    "radius": { "$value": "0.25rem", "$type": "dimension" },
    "sea": { "$value": "{primitive.color.sea.500}", "$type": "color" },
    "sea-bright": { "$value": "{primitive.color.sea.300}", "$type": "color" },
    "sea-deep": { "$value": "{primitive.color.sea.700}", "$type": "color" },
    "ember": { "$value": "{primitive.color.ember.400}", "$type": "color" },
    "ember-deep": { "$value": "{primitive.color.ember.800}", "$type": "color" },
    "grout": { "$value": "{primitive.color.stone.950}", "$type": "color" },
    "stone-face": { "$value": "{primitive.color.stone.800}", "$type": "color" },
    "stone-face-bright": { "$value": "{primitive.color.stone.600}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-settle": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-tide": { "$value": "{primitive.motion.ease.tide}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-settle": { "$value": "{primitive.motion.duration.settle}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "flagstone": {
      "grout-width": { "$value": "0.6rem", "$type": "dimension" },
      "tilt-max": { "$value": "1.4deg", "$type": "dimension" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 30% 20%, rgba(217, 125, 74, 0.16), transparent 60%)",
        "$type": "gradient"
      },
      "night-vignette": {
        "$value": "radial-gradient(ellipse 120% 80% at 50% -10%, rgba(22, 17, 13, 0), rgba(22, 17, 13, 0.9) 85%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.stone.100}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.stone.950}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.sea.300}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.stone.950}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.stone.600}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.ember.400}", "$type": "color" }
    }
  }
}
